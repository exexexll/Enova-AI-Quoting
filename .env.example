# Backend (DigitalOcean / local)
# Copy to .env and fill in real values. Do not commit .env.

# Required for AI and image search
OPENAI_API_KEY=
SERPAPI_KEY=

# Optional: override data directory (e.g. mounted volume path)
# DATA_DIR=/mnt/data

# Optional: paths to ingredient master and MFSO template
# INGREDIENT_MASTER_PATH=/path/to/Ingredient Master.xlsx
# MFSO_TEMPLATE_PATH=/path/to/MFSO-template.pdf

# Future: PostgreSQL (when migrating from SQLite)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ---------------------------------------------------------------------------
# Frontends (Vercel) – set in each project (client + admin) to the SAME value
# so admin and client portals connect to the same backend.
# ---------------------------------------------------------------------------
# VITE_API_URL=https://your-backend.ondigitalocean.app
